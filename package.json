{
  "name": "tarsa",
  "version": "0.1.0",
  "type": "module",
  "description": "Real-time Claude Code agent observability tool",
  "author": "Camilo Pestana",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elcronos/tarsa.git"
  },
  "homepage": "https://github.com/elcronos/tarsa#readme",
  "bugs": {
    "url": "https://github.com/elcronos/tarsa/issues"
  },
  "keywords": [
    "claude-code",
    "observability",
    "agents",
    "hooks",
    "telemetry",
    "dashboard"
  ],
  "files": [
